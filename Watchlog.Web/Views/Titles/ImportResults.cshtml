@model Watchlog.Models.ViewModels.ImportResultsViewModel;

@{
    ViewData["Title"] = "Import results";
}

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h2 class="mb-1">Results</h2>
            <div class="text-muted">
                Search: <strong>@Model.Query</strong>
            </div>
        </div>

        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" asp-action="Import">New search</a>
            <a class="btn btn-outline-secondary" asp-action="Index">Catalog</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4">
                    <h4 class="mb-3">TV Series</h4>

                    @if (Model.TvResults == null || !Model.TvResults.Any())
                    {
                        <div class="text-muted">No TV results.</div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var item in Model.TvResults)
                            {
                                <div class="list-group-item d-flex align-items-center justify-content-between py-3">
                                    <div class="me-3">
                                        <div class="fw-semibold">@item.DisplayName</div>
                                        <div class="text-muted small">@item.DisplayDate</div>
                                    </div>

                                    <form asp-action="ImportSelected" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="tmdbId" value="@item.Id" />
                                        <input type="hidden" name="type" value="tv" />
                                        <button type="submit" class="btn btn-sm btn-primary">
                                            Import
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4">
                    <h4 class="mb-3">Movies</h4>

                    @if (Model.MovieResults == null || !Model.MovieResults.Any())
                    {
                        <div class="text-muted">No movie results.</div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var item in Model.MovieResults)
                            {
                                <div class="list-group-item d-flex align-items-center justify-content-between py-3">
                                    <div class="me-3">
                                        <div class="fw-semibold">@item.DisplayName</div>
                                        <div class="text-muted small">@item.DisplayDate</div>
                                    </div>

                                    <form asp-action="ImportSelected" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="tmdbId" value="@item.Id" />
                                        <input type="hidden" name="type" value="movie" />
                                        <button type="submit" class="btn btn-sm btn-primary">
                                            Import
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>